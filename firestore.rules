rules_version = '2';

// - config/branding: precisa ser público para LEITURA porque a página de
//   login carrega o logo/fondo ANTES de a pessoa estar logada. Sin esta
//   regra específica, a leitura era bloqueada e por isso o logo/fondo
//   novo nunca aparecia no próximo login.
// - Todo lo demás sigue exigiendo estar logueado.
service cloud.firestore {
  match /databases/{database}/documents {

    match /config/branding {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
