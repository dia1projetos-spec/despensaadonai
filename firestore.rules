rules_version = '2';

// Reglas básicas: solo un usuario logueado (vos, desde el panel admin)
// puede leer o escribir cualquier dato del sistema.
// Copiar y pegar esto en: Firebase Console → Firestore Database → Reglas.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
